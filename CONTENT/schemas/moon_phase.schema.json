{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Moon Phase Content",
  "description": "Schema for moon phase content in Content System",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["phase_id", "name", "human_text"],
    "properties": {
      "phase_id": {
        "type": "string",
        "description": "Unique identifier for the moon phase",
        "pattern": "^[a-z_]+$"
      },
      "name": {
        "type": "string",
        "description": "Human-readable name of the phase"
      },
      "themes": {
        "type": "string",
        "description": "Semantic themes for the phase"
      },
      "guidance": {
        "type": "string",
        "description": "Semantic guidance for the phase"
      },
      "human_text": {
        "type": "string",
        "description": "Human-readable text (generated by Human Layer)",
        "minLength": 10
      }
    }
  }
}

