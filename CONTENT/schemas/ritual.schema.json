{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ritual Content",
  "description": "Schema for ritual content in Content System",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["ritual_id", "title", "human_text"],
    "properties": {
      "ritual_id": {
        "type": "string",
        "description": "Unique identifier for the ritual"
      },
      "title": {
        "type": "string",
        "description": "Title of the ritual"
      },
      "intention": {
        "type": "string",
        "description": "Semantic intention"
      },
      "instructions": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Step-by-step instructions"
      },
      "notes": {
        "type": "string",
        "description": "Additional notes"
      },
      "human_text": {
        "type": "string",
        "description": "Human-readable text (generated by Human Layer)",
        "minLength": 10
      }
    }
  }
}

