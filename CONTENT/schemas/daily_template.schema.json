{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Daily Template Content",
  "description": "Schema for daily template content in Content System",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["template_id", "type", "text", "human_text"],
    "properties": {
      "template_id": {
        "type": "string",
        "description": "Unique identifier (e.g., DAILY.AFFIRMATION.001)"
      },
      "type": {
        "type": "string",
        "enum": ["AFFIRMATION", "DIGEST", "FOCUS", "PATTERN_TODAY", "PRACTICE", "PROMPT", "WARNING", "WIN"],
        "description": "Type of daily template"
      },
      "category": {
        "type": "string",
        "description": "Category for grouping"
      },
      "text": {
        "type": "string",
        "description": "Original/semantic text"
      },
      "human_text": {
        "type": "string",
        "description": "Human-readable text (generated by Human Layer)",
        "minLength": 10
      },
      "pattern": {
        "type": "string",
        "description": "Pattern type (for PATTERN_TODAY)"
      },
      "practice_type": {
        "type": "string",
        "description": "Practice type (for PRACTICE)"
      },
      "instructions": {
        "type": "string",
        "description": "Instructions (for PRACTICE)"
      }
    }
  }
}

