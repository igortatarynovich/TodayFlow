# Copy to `.env` on the server before: docker compose -f docker-compose.prod.yml up -d --build
#
# Public URLs (must match your reverse proxy / DNS)
PUBLIC_WEB_URL=https://todayflow.app
PUBLIC_API_URL=https://api.todayflow.app

# Secrets — generate strong values for production
AUTH_JWT_SECRET=replace-with-long-random-secret
POSTGRES_PASSWORD=replace-with-strong-db-password

# Email (required for magic links outside dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@todayflow.app

# Optional: OpenAI for narrative generation
OPENAI_API_KEY=

# Optional: Stripe live mode
PAYMENTS_MODE=mock
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional: OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
