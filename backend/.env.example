ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/todayflow
ASTRO_SERVICE_URL=http://localhost:8081
NARRATIVE_MODEL_VERSION=1.0.0
CONTENT_VERSION=1.0.0
I18N_VERSION=1.0.0
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
AUTH_JWT_SECRET=replace_me

# OAuth (optional): Google One Tap / GIS uses GOOGLE_CLIENT_ID; redirect flow also needs GOOGLE_CLIENT_SECRET.
# Apple Sign In (web / native): APPLE_CLIENT_ID (Services ID / bundle id per platform).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=whsec_xxx

# AI: генерация текстов. Без ключа — deterministic / Lexicon fallback (без LLM).
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=          # vLLM / LiteLLM / прокси
# LLM_CHAT_API_KEY=         # альтернативный ключ (приоритетнее OPENAI_API_KEY)
# LLM_DEFAULT_MODEL=gpt-4o-mini

# Nebius Token Factory (OpenAI-compatible): https://docs.tokenfactory.nebius.com/
# LLM_PROVIDER=nebius
# NEBIUS_API_KEY=
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# NEBIUS_MODEL=deepseek-ai/DeepSeek-V4-Pro

# LLM_QUALITY_MODE=rich       # default: multi-step funnels, generous max_tokens
# LLM_QUALITY_MODE=economize  # legacy AMLL cost control

# Gemini (Google AI Studio): https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# LLM_PROVIDER=gemini        # переключить весь backend на Gemini вместо OpenAI
